# ══════════════════════════════════════════════════════════════
# GreenSteps India — Backend Environment Variables Template
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# ⚠️  NEVER commit your actual .env file to Git.
# ══════════════════════════════════════════════════════════════

# ─── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
# Options: development | production | test

# ─── Database ────────────────────────────────────────────────
# MongoDB Atlas connection string
# Get yours from: https://cloud.mongodb.com → Connect → Drivers
# Leave empty to use in-memory mock database (development only)
MONGO_URI=mongodb+srv://<USERNAME>:<PASSWORD>@cluster0.xxxxx.mongodb.net/greensteps?retryWrites=true&w=majority&appName=Cluster0

# ─── Firebase Admin SDK ──────────────────────────────────────
# Download from: Firebase Console → Project Settings → Service Accounts
# → Generate new private key → Download JSON
# Leave all empty to use Mock Authentication (development only)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the private_key value from the JSON file (keep the quotes and \n characters)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9...\n-----END PRIVATE KEY-----\n"

# ─── Security ────────────────────────────────────────────────
# Strong random string for signing developer JWT tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret-string-in-production

# ─── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# In production, set this to your actual frontend URL
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
