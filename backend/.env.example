# GreenSteps India - Backend Environment Configuration
PORT=5000
NODE_ENV=development

# Database Setup (Leave empty to trigger in-memory mock fallback)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/greensteps?retryWrites=true&w=majority

# Firebase Admin SDK Configuration for live JWT verification
# If left empty, backend falls back to standard developer payload authentication
FIREBASE_PROJECT_ID=greensteps-india-xxxx
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@greensteps-india.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n"

# JWT secret key for development mock session sign-in
JWT_SECRET=supersecretgreenstepsindiadevelopmentkey
