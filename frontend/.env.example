# ══════════════════════════════════════════════════════════════
# GreenSteps India — Frontend Environment Variables Template
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# ⚠️  NEVER commit your actual .env file to Git.
# ⚠️  All VITE_ variables are bundled into the JS build.
#     Do NOT put secrets here.
# ══════════════════════════════════════════════════════════════

# ─── Backend API ─────────────────────────────────────────────
# Local development (default)
VITE_API_URL=http://localhost:5000/api/v1
# Production example:
# VITE_API_URL=https://greensteps-api-xxxx.a.run.app/api/v1

# ─── Firebase Client SDK ─────────────────────────────────────
# Get from: Firebase Console → Project Settings → General
# → Your apps → Web app → SDK setup and configuration
#
# Leave all empty to activate Developer Mock Mode automatically.
# In Mock Mode: any email/password works, no real auth happens.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Developer Options ───────────────────────────────────────
# Force Mock Mode even if Firebase keys are present
# Set to "true" to bypass all Firebase checks during testing
VITE_MOCK_MODE=false

# ─── App Config ──────────────────────────────────────────────
VITE_APP_NAME=GreenSteps India
VITE_APP_VERSION=1.0.0
